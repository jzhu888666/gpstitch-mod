<layout>
    <!-- Date and Time (top-left) -->
    <composite x="28" y="28" name="date_time">
        <component type="datetime" x="0" y="0" format="%Y/%m/%d" size="22" align="left"/>
        <component type="datetime" x="0" y="34" format="%H:%M:%S" size="44" align="left"/>
    </composite>

    <!-- Speed (bottom-left) -->
    <composite x="28" y="1134" name="speed">
        <component type="metric_unit" x="0" y="0" metric="speed" units="speed" size="22">{:~c}</component>
        <component type="metric" x="0" y="0" metric="speed" units="speed" dp="0" size="226"/>
    </composite>

    <!-- Altitude (bottom-left, below speed) -->
    <composite x="28" y="1388" name="altitude">
        <component type="metric_unit" x="100" y="0" metric="alt" units="alt" size="22">ALT({:~C})</component>
        <component type="icon" x="0" y="0" file="mountain.png" size="90"/>
        <component type="metric" x="100" y="26" metric="alt" units="alt" dp="0" size="44"/>
    </composite>

    <!-- Gradient (bottom-center-left) -->
    <composite x="312" y="1388" name="gradient">
        <component type="text" x="100" y="0" size="22">SLOPE(%)</component>
        <component type="icon" x="0" y="0" file="slope-triangle.png" size="90"/>
        <component type="metric" x="100" y="26" metric="gradient" dp="0" size="44"/>
    </composite>

    <!-- Gradient chart -->
    <component type="chart" name="gradient_chart" x="566" y="1388"/>

    <!-- Camera info (bottom-right) -->
    <composite x="2606" y="1218" name="camera_info">
        <component type="text" x="-142" y="0" size="20" align="right">ISO</component>
        <component type="metric" x="-142" y="26" metric="iso" dp="0" size="40" align="right"/>

        <component type="text" x="0" y="0" size="20" align="right">F/</component>
        <component type="metric" x="0" y="26" metric="fnum" dp="1" size="40" align="right"/>
    </composite>

    <composite x="2606" y="1318" name="camera_info_2">
        <component type="text" x="-142" y="0" size="20" align="right">EV</component>
        <component type="metric" x="-142" y="26" metric="ev" dp="1" size="40" align="right"/>

        <component type="text" x="0" y="0" size="20" align="right">CT</component>
        <component type="metric" x="0" y="26" metric="ct" dp="0" size="40" align="right"/>
    </composite>

    <!-- GPS info (top-right, above map) -->
    <composite x="2330" y="0" name="gps_info">
        <frame name="gps-lock" x="320" y="34" width="46" height="46" bg="0,0,0,128" cr="7" opacity="0.4">
            <component type="gps-lock-icon" size="46"/>
        </frame>

        <composite y="52">
            <component type="text" x="0" y="0" size="22" align="left">GPS INFO</component>
            <component type="text" x="0" y="34" size="22" align="left">Lat: </component>
            <component type="text" x="182" y="34" size="22" align="left">Lon: </component>
            <component type="metric" x="168" y="34" metric="lat" dp="6" size="22" align="right" cache="False"/>
            <component type="metric" x="362" y="34" metric="lon" dp="6" size="22" align="right" cache="False"/>
        </composite>
    </composite>

    <!-- Maps (right side) -->
    <component type="moving_map" name="moving_map" x="2330" y="142" size="362" zoom="16" corner_radius="50"/>
    <component type="journey_map" name="journey_map" x="2330" y="532" size="362" corner_radius="50"/>
</layout>
